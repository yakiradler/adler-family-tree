VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI photo-scan backend (optional). Leave both unset to run the scan flow in
# clearly-labelled DEMO mode (sample data, no real analysis).
#   VITE_AI_VISION_URL  — a custom HTTP endpoint that accepts files as base64
#                         JSON and returns { candidates: [...] }.
#   VITE_AI_VISION_EDGE — set to "true" ONLY when the `parse-family-document`
#                         Supabase Edge Function is actually deployed.
# VITE_AI_VISION_URL=
# VITE_AI_VISION_EDGE=false
